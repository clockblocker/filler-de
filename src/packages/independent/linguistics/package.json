{
	"name": "@textfresser/linguistics",
	"private": true,
	"type": "module",
	"version": "0.0.0",
	"dependencies": {
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@types/bun": "1.3.0",
		"typescript": "5.9.3"
	},
	"exports": {
		".": "./src/index.ts",
		"./common": "./src/common/index.ts",
		"./common/*": "./src/common/*",
		"./de": "./src/de/index.ts",
		"./de/*": "./src/de/*",
		"./en": "./src/en/index.ts",
		"./en/*": "./src/en/*"
	},
	"scripts": {
		"build": "bun ../../../../scripts/build-workspace-package.ts",
		"fix": "bun x biome check --write --unsafe . 2>/dev/null || true",
		"test": "bun test --reporter=dot --preload ../../../../tests/unit/setup.ts ./tests/"
	}
}
